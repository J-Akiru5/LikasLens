{
  "versionGroups": [
    {
      "label": "Use workspace protocol for internal packages",
      "dependencies": ["$LOCAL"],
      "dependencyTypes": ["dev", "prod"],
      "pinVersion": "workspace:*"
    }
  ],
  "semverGroups": [
    {
      "range": "^",
      "dependencies": ["**"],
      "packages": ["**"]
    }
  ],
  "sortFirst": ["name", "version", "description", "private", "scripts"],
  "source": ["package.json", "apps/*/package.json"]
}
