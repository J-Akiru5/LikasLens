# AI Service Configuration
AI_SERVICE_PORT=8001

# Google Generative AI (Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# Azure Cosmos DB Gremlin
COSMOS_GREMLIN_CONNECTION_STRING=AccountEndpoint=https://your-account.gremlin.cosmos.azure.com:443/;AccountKey=your-key;Database=likaslens;Graph=likaslens-graph

# Environment
ENVIRONMENT=development
