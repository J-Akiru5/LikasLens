{
  "mcpServers": {
    "github": {
      "command": "node",
      "args": [
        "-e",
        "const GitHubMCPServer = require('@modelcontextprotocol/server-github'); new GitHubMCPServer().start();"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${env:GITHUB_TOKEN}"
      }
    }
  }
}
